# ── Base de datos ─────────────────────────────────────────────────
# Local (Docker): mongodb://localhost:27017/share_notes
# Local con Docker Compose (con auth): mongodb://admin:sharenotes123@localhost:27017/share_notes?authSource=admin
# MongoDB Atlas: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/share_notes?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/share_notes
MONGO_URI_TEST=mongodb://localhost:27017/share_notes_test

# Credenciales para MongoDB local con Docker Compose
# Se usan automáticamente por docker-compose.yml como valores por defecto
# MONGO_USERNAME=admin
# MONGO_PASSWORD=sharenotes123

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=tu_secreto_super_seguro_cambiame_en_produccion
JWT_EXPIRES_IN=7d

# ── Servidor ──────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Frontend (CORS) ───────────────────────────────────────────────
# Local: http://localhost:5173
# Producción: https://share-notes-frontend.onrender.com
CLIENT_URL=http://localhost:5173

# ── Google OAuth (Login) ──────────────────────────────────────────
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-secret-key
# Local: http://localhost:4000/api/auth/google/callback
# Producción: https://share-notes-api.onrender.com/api/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ── Google Service Account (Google Docs API) ──────────────────────
# 1. Crea una cuenta de servicio en Google Cloud Console
# 2. Genera una clave JSON
# 3. Copia TODO el JSON en una sola línea y pégala aquí
# IMPORTANTE: Habilita Google Docs API y Google Drive API en tu proyecto
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"...",...}
