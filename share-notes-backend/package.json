"jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFiles": [
      "dotenv/config"
    ],
    "transform": {},
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js",
      "!src/config/**",
      "!src/tests/**",
      "!src/service-account.json",
      "!src/routes/**",
      "!src/app.js",
      "!src/middlewares/rateLimiter.middleware.js",
      "!src/controllers/googleDocs.controller.js",
      "!src/controllers/docxExport.controller.js",
      "!src/controllers/file.controller.js",
      "!src/services/googleDocs.service.js"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 64,
        "branches": 64,
        "functions": 64,
        "lines": 64
      }
    }
  }
}