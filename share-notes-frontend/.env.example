# URL base del backend (incluye /api)
# Local desarrollo (proxy Vite): dejar VACÍO → se usa "/api" por defecto
# Local Docker Compose: http://localhost:4000
# Producción (Render): https://share-notes-api.onrender.com/api
VITE_API_URL=

# URL base del backend (sin /api) — para WebSocket/Socket.IO
# Local desarrollo: dejar VACÍO → se usa el origin actual
# Local Docker Compose: http://localhost:4000
# Producción (Render): https://share-notes-api.onrender.com
VITE_BACKEND_URL=
